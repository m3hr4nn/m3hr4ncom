# Hugo output directory
/public/

# OS files
.DS_Store
Thumbs.db

# IDE/Editor files
.vscode/
.idea/

# Logs
*.log
error_log

# cPanel deployment archives
allfiles.tar.gz
*.tar.gz

# CV PDFs + sources — keep local, never commit/publish from the repo (PII).
# The live CV is served from cPanel directly, not via git. **/ covers version
# archives too (e.g. v/v3-base/assets/).
**/assets/*.pdf
**/assets/*.tex

# Backup and temp files
*.bak
*.swp
*.swo
*.tmp

# Node modules
/node_modules/

# Python virtual envs
/venv/
/__pycache__/

# Hugo build
/resources/_gen/

# Generated files
hugo_stats.json

# Favicon generator download bundle (contents already extracted alongside it)
**/favicon.zip

# Markdown: only README.md is public. Internal docs (agent instructions,
# planning notes, scratch) stay local and out of GitHub.
*.md
!README.md

